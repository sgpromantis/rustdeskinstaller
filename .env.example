# RustDesk Generator Environment Configuration
# Copy this file to .env and fill in your values

# Django Core (Required)
SECRET_KEY=change-this-to-a-random-50-char-string
GENURL=https://rustdesk.promantis.de
DJANGO_DEBUG=False

# GitHub Configuration (Required for the web UI to trigger builds)
GHUSER=sgpromantis
GHBEARER=your_github_personal_access_token
REPONAME=rustdeskinstaller
PROTOCOL=https
